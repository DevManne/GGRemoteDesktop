<?xml version="1.0" encoding="UTF-8"?>
<!--
  Host app Info.plist. The usage-description strings are shown in the macOS permission
  prompts; see docs/SETUP.md for the full list of required keys and entitlements.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleName</key>
  <string>RemoteMac Host</string>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
  <key>NSScreenCaptureUsageDescription</key>
  <string>RemoteMac streams this Mac's screen to your trusted device.</string>
  <key>NSMicrophoneUsageDescription</key>
  <string>Optionally stream this Mac's audio to your trusted device.</string>
  <key>NSLocalNetworkUsageDescription</key>
  <string>RemoteMac discovers your trusted device on the local network.</string>
  <key>NSBonjourServices</key>
  <array>
    <string>_remotemac._tcp</string>
  </array>
</dict>
</plist>
